@model IEnumerable<mobileshop.Models.Product>
    @{
        ViewBag.Title = "Mobile Shop - Home";
    }

                      <div class="container mt-4">
                          <div class="row mb-5 justify-content-center">
                              <div class="col-md-8 text-center">
                                  <h1 class="mb-4 fw-bold text-dark">Find Your Perfect Mobile</h1>

                                  @using (Html.BeginForm("Index", "Product", FormMethod.Get, new { @class = "d-flex shadow-sm rounded overflow-hidden" }))
                                  {
                                      <input type="text" name="searchString" class="form-control border-0 p-3"
                                             placeholder="Search mobiles..."
                                             value="@Request.QueryString["searchString"]"
                                             style="font-size: 1.1rem; border-radius: 10px 0 0 10px;" />

                                      <button type="submit" class="btn btn-primary px-4 border-0" style="border-radius: 0 10px 10px 0;">
                                          <i class="bi bi-search"></i> Search
                                      </button>
                                  }
                              </div>
                          </div>

                          <hr class="mb-5" />

                          <div class="d-flex justify-content-between align-items-center mb-4">
                              <h3 class="fw-bold text-dark">Our Collection</h3>

                              <div class="dropdown">
                                  <button class="btn btn-outline-secondary dropdown-toggle rounded-pill shadow-sm" type="button" id="filterDropdown" data-bs-toggle="dropdown">
                                      <i class="bi bi-filter-right"></i> Sort By Price
                                  </button>
                                  <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                      <li>
                                          <a class="dropdown-item py-2" href="@Url.Action("Index", new { sortOrder = "Price_Desc", searchString = Request.QueryString["searchString"] })">
                                              <i class="bi bi-sort-numeric-down-alt text-danger"></i> High to Low
                                          </a>
                                      </li>
                                      <li>
                                          <a class="dropdown-item py-2" href="@Url.Action("Index", new { sortOrder = "Price_Asc", searchString = Request.QueryString["searchString"] })">
                                              <i class="bi bi-sort-numeric-up text-success"></i> Low to High
                                          </a>
                                      </li>
                                  </ul>
                              </div>
                          </div>

                          <div class="row">
                              @if (Model != null && Model.Any())
                              {
                                  foreach (var item in Model)
                                  {
                                      <div class="col-md-3 mb-4">
                                          <div class="card h-100 shadow-sm border-0">
                                              <img src="@Url.Content(item.Image)" class="card-img-top p-3" style="height:200px; object-fit:contain;">
                                              <div class="card-body d-flex flex-column text-center" style="min-height: 220px;">
                                                  @* Product Name and Price *@
                                                  <h6 class="fw-bold text-dark mb-1">@item.ProductName</h6>
                                                  <p class="text-success fw-bold mb-3">₹ @item.Price.ToString("N2")</p>

                                                  @* --- FIXED BUTTON GROUP:  --- *@
                                                  <div class="mt-auto d-grid gap-2" style="position: relative; z-index: 10;">
                                                      @* 1. View Details Button *@
                                                      <a href="@Url.Action("Details", "Product", new { id = item.Id })"
                                                         class="btn btn-outline-primary btn-sm rounded-pill py-2 shadow-sm"
                                                         style="border-width: 2px; display: block !important;">
                                                          <i class="bi bi-info-circle"></i> View Details
                                                      </a>

                                                      @* 2. Add to Cart Button *@
                                                      <a href="@Url.Action("AddToCart", "Cart", new { id = item.Id })"
                                                         class="btn btn-primary btn-sm rounded-pill py-2 shadow-sm"
                                                         style="display: block !important;">
                                                          <i class="bi bi-cart-plus-fill"></i> Add to Cart
                                                      </a>
                                                  </div>
                                              </div>
                                          </div>
                                      </div>
                                  }
                              }
                          </div>
                      </div>
