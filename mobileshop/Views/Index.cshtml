@model IEnumerable<mobileshop.Models.Cart>

    <div class="container mt-4">
        <h2>My Shopping Cart</h2>

        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Cart ID</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                       
                            <td>@(item.Product != null ? item.Product.ProductName : "N/A")</td>
                            <td>₹ @(item.Product != null ? item.Product.Price.ToString() : "0")</td>
                            <td>@item.Quantity</td>
                            <td>@item.Id</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

