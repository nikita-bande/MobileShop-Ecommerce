@model IEnumerable<mobileshop.Models.Order>
    @using System.Web.Mvc
    @using System.Web.Mvc.Html

    <div class="container mt-5">
        <h2 class="text-primary mb-4"><i class="bi bi-bag-check"></i> My Purchase History</h2>

        @if (Model.Any())
        {
            <div class="table-responsive shadow-sm rounded">
                <table class="table table-hover align-middle bg-white">
                    <thead class="table-dark">
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Total Amount</th>
                            <th style="width: 250px;">Status Tracking</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>#@order.OrderId</strong></td>
                                <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                                <td class="text-success fw-bold">₹@order.TotalAmount</td>
                                <td>
                                    @* --- Progress Bar Section (Amazon Style) --- *@
                                    <div class="progress mb-1" style="height: 8px;">
                                        @if (order.Status == "Pending")
                                        {
                                            <div class="progress-bar bg-warning" style="width: 30%;"></div>
                                        }
                                        else if (order.Status == "Shipped")
                                        {
                                            <div class="progress-bar bg-info" style="width: 65%;"></div>
                                        }
                                        else if (order.Status == "Delivered")
                                        {
                                            <div class="progress-bar bg-success" style="width: 100%;"></div>
                                        }
                                        else if (order.Status == "Cancelled")
                                        {
                                            <div class="progress-bar bg-danger" style="width: 100%;"></div>
                                        }
                                    </div>
                                    <div class="d-flex justify-content-between text-muted mt-1" style="font-size: 0.75rem;">
                                        <span>Ordered</span>
                                        <span>Shipped</span>
                                        <span>Delivered</span>
                                    </div>

                                    @* Status Badge *@
                                    <span class="badge @(order.Status == "Pending" ? "bg-warning text-dark" :
                                                   order.Status == "Cancelled" ? "bg-danger" : "bg-success")">
                                        @order.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
    <div class="alert alert-info">You have not placed any orders so far.</div>
        }
    </div>
