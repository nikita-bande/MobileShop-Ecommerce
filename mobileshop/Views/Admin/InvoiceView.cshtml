@model mobileshop.Models.Order
@{ Layout = null; }

<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            padding: 30px;
        }

        .invoice-header {
            border-bottom: 2px solid #333;
            padding-bottom: 20px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="invoice-header d-flex justify-content-between">
        <div>
            <h1>MobileShop</h1>
            <p>Latur, Maharashtra</p>
        </div>
        <div class="text-end">
            <h3>INVOICE</h3>
          
            <p>Order ID: #@Model.OrderId</p>
            <p>Date: @Model.OrderDate.ToShortDateString()</p>
        </div>
    </div>

    <div class="mb-4">
        <h5>Customer Details:</h5>
      
        <p><strong>Customer:</strong> @Model.CustomerName</p>
        <p><strong>Phone:</strong> @Model.Phone</p>
        <p><strong>Address:</strong> @Model.Address</p>
        <p><strong>Status:</strong> @Model.Status</p>
    </div>

    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Product Description</th>
                <th class="text-end">Amount</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Mobile Purchase (Order ID: #@Model.OrderId)</td>
                <td class="text-end">₹ @Model.TotalAmount</td>
            </tr>
        </tbody>
        <tfoot>
            <tr>
                <th class="text-end">Grand Total:</th>
                <th class="text-end text-success">₹ @Model.TotalAmount</th>
            </tr>
        </tfoot>
    </table>

    <div class="mt-5 text-center">
        <p>Thank you for shopping with MobileShop!</p>
        <small class="text-muted">This is a computer-generated invoice.</small>
    </div>
</body>
</html>