@model IEnumerable<mobileshop.Models.Product>
    @using System.Web.Mvc
    @using System.Web.Mvc.Html
    @{
        ViewBag.Title = "Admin Dashboard";
    }

    <div class="container mt-4">
        <div class="card shadow-sm border-0 p-4">
            <div class="row align-items-center mb-4">
                <div class="col-md-4">
                    <h2 class="text-primary mb-0">Admin Panel</h2>
                    <p class="text-muted small">Manage your mobile inventory</p>
                </div>

                <div class="col-md-5">
            
                    @using (Html.BeginForm("Index", "Admin", FormMethod.Get, new { @class = "d-flex" }))
                    {
                        <div class="input-group">
                            <input type="text" name="searchString" class="form-control"
                                   placeholder="Search mobile name..."
                                   value="@(Request.QueryString["searchString"] ?? "")" />
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search"></i> Search
                            </button>
                            @if (!string.IsNullOrEmpty(Request.QueryString["searchString"]))
                            {
                                <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary">Reset</a>
                            }
                        </div>
                    }
                </div>

                <div class="col-md-3 text-end">
                    <a href="@Url.Action("Create", "Admin")" class="btn btn-success shadow-sm">
                        <i class="bi bi-plus-lg"></i> + Add New Mobile
                    </a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle border">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 10%;">ID</th>
                            <th style="width: 15%;">Image</th>
                            <th style="width: 35%;">Product Name</th>
                            <th style="width: 20%;">Price</th>
                            <th style="width: 20%;" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>#@item.Id</strong></td>
                                    <td>
                                        <img src="@Url.Content(item.Image)" alt="mobile"
                                             class="rounded shadow-sm" style="height:50px; width:50px; object-fit:contain;" />
                                    </td>
                                    <td>@item.ProductName</td>
                                    <td class="text-success fw-bold">₹ @item.Price.ToString("N2")</td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a href="@Url.Action("Edit", "Admin", new { id = item.Id })"
                                               class="btn btn-sm btn-outline-warning">Edit</a>
                                            <a href="@Url.Action("Delete", "Admin", new { id = item.Id })"
                                               class="btn btn-sm btn-outline-danger"
                                               onclick="return confirm('Nikita, Do you really want to delete this mobile?')">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <h5>No mobiles found!</h5>
                                    <p>Try a different search term or add a new product.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
