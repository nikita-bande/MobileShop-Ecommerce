@model IEnumerable<mobileshop.Models.User>

    <div class="container mt-4">
        <h2 class="text-primary border-bottom pb-2">
            <i class="bi bi-people-fill"></i> Registered Users
        </h2>
        <table class="table table-striped table-hover mt-3 shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>User ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>
                            <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">
                                @user.Role
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
