@using System.Web.Mvc
@using System.Web.Mvc.Html
@using mobileshop.Models

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MobileShop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f9fa;
        }

        .navbar {
            box-shadow: 0 2px 4px rgba(0,0,0,.1);
        }

        .footer {
            background: #343a40;
            color: white;
            padding: 20px 0;
            margin-top: 50px;
        }

        .nav-link:hover {
            color: #ffc107 !important;
            transition: 0.3s;
        }

        .badge-cart {
            position: relative;
            top: -10px;
            left: -5px;
            font-size: 0.7rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="@Url.Action("Index", "Product")">
                <i class="bi bi-phone"></i> MobileShop
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Product")">Home</a></li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("ViewCart", "Cart")">
                            Cart <span class="badge bg-danger badge-cart">@(Session["cart"] != null ? ((List<Product>)Session["cart"]).Count : 0)</span>
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    @if (Session["UserName"] != null)
                    {
                        <li class="nav-item"><span class="nav-link text-info fw-bold me-3">Hi, @Session["UserName"]</span></li>
                        <li class="nav-item"><a class="nav-link text-info fw-bold" href="@Url.Action("MyOrders", "Account")">My Orders</a></li>

                        @* --- Role Based Admin Section Updates --- *@
                        if (Session["UserRole"] != null && Session["UserRole"].ToString() == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold small" href="@Url.Action("Dashboard", "Admin")">
                                    <i class="bi bi-graph-up"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold small" href="@Url.Action("Orders", "Admin")">
                                    <i class="bi bi-cart-check"></i> Orders
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold small" href="@Url.Action("Index", "Admin")">
                                    <i class="bi bi-box-seam"></i> Products
                                </a>
                            </li>
                        }

                        <li class="nav-item"><a class="btn btn-outline-danger btn-sm ms-2" href="@Url.Action("Logout", "Account")">Logout</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Login", "Account")">Login</a></li>
                        <li class="nav-item"><a class="btn btn-primary btn-sm px-3 ms-2" href="@Url.Action("Register", "Account")">Register</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content" style="min-height: 80vh;">
        @RenderBody()
    </div>

    <footer class="footer text-center mt-auto">
        <div class="container">
            <p>&copy; @DateTime.Now.Year - MobileShop India (@@Nikita Bande Project)</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>