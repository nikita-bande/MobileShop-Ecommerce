@using mobileshop.Models
@model List<Product>
    @{
        ViewBag.Title = "My Cart - Mobile Shop";
    }

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-12">
                <h2 class="mb-4 text-primary">Your Shopping Cart</h2>

                <div class="table-responsive">
                    <table class="table table-hover table-bordered shadow-sm">
                        <thead class="table-dark">
                            <tr>
                                <th>Product Name</th>
                                <th class="text-center">Price</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="align-middle">@item.ProductName</td>
                                        <td class="text-center align-middle">₹ @item.Price.ToString("N2")</td>
                                        <td class="text-center">
                                       
                                            <a href="@Url.Action("RemoveFromCart", "Cart", new { id = item.Id })"
                                               class="btn btn-outline-danger btn-sm">Remove</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">
                                        <h5>Your cart is empty!</h5>
                                        <p>Browse our products to add items here.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model != null && Model.Any())
                {
                    <div class="card mt-3 shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                @* Explicit casting to decimal for Sum calculation *@
                                @{
                                    var total = Model.Sum(p => (decimal)p.Price);
                                }
                                <h4 class="mb-0">Total Amount:</h4>
                                <h3 class="text-success mb-0 font-weight-bold">₹ @total.ToString("N2")</h3>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4 mb-5">
                        <a href="@Url.Action("Index", "Product")" class="btn btn-secondary btn-lg px-4">
                            &larr; Continue Shopping
                        </a>
                        <a href="@Url.Action("Checkout", "Cart")" class="btn btn-primary btn-lg px-5 shadow">
                            Proceed to Checkout &rarr;
                        </a>
                    </div>
                }
                else
                {
                    <div class="text-center mt-4">
                        <a href="@Url.Action("Index", "Product")" class="btn btn-primary btn-lg">
                            Start Shopping Now
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
