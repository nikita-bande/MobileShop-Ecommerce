@{
    ViewBag.Title = "Order Success - Mobile Shop";
}

<style>

    .success-animation {
        animation: scaleAndFadeIn 0.8s ease-out;
    }

    @@keyframes scaleAndFadeIn {
        0% {
            transform: scale(0.8);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .confetti-icon {
        font-size: 80px;
        color: #28a745;
        margin-bottom: 20px;
        /* Icon ke liye thoda bounce effect */
        animation: bounce 1.5s infinite;
    }

    @@keyframes bounce {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    .order-card {
        background: #fff;
        padding: 50px;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        border: none;
    }
</style>

<div class="container mt-5 success-animation">
    <div class="row justify-content-center text-center">
        <div class="col-md-8">
            <div class="order-card shadow-lg">
                @* Big Green Check Icon with Animation *@
                <div class="confetti-icon">
                    <i class="bi bi-check-circle-fill"></i>
                </div>

                <h1 class="display-4 fw-bold text-success mb-3">Order Placed!</h1>

                <p class="lead text-dark">
                    Thank you, <strong>@(Session["UserName"] ?? "Customer")</strong>!
                    Your order has been successfully placed.
                </p>

                <p class="text-muted mb-4">
                    Your mobile is on its way. We have received your order and our team is working on it.
                    You will receive a confirmation message shortly.
                </p>

                <hr class="my-4">

                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                    <a href="@Url.Action("Index", "Product")" class="btn btn-primary btn-lg px-5 rounded-pill shadow">
                        <i class="bi bi-cart-check"></i> Continue Shopping
                    </a>
                    <a href="@Url.Action("MyOrders", "Account")" class="btn btn-outline-success btn-lg px-5 rounded-pill shadow-sm">
                        <i class="bi bi-bag-check"></i> View My Orders
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>